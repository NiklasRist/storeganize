{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "storeganise-ttlock-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-16",
	"compatibility_flags": ["nodejs_compat"],
	"observability": { "enabled": true },
	"assets": {
		"directory": "./public/",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "ttlock-logs",
			"database_id": "b3a4a038-e72c-49a6-aeca-c5bf466195d6"
		}
	]
}
